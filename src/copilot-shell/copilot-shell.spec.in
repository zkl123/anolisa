%define anolis_release 1
%global debug_package %{nil}

Name:           copilot-shell
Version:        @VERSION@
Release:        %{anolis_release}%{?dist}
Summary:        Copilot Shell - Entrance to AI-native OS
License:        Apache-2.0
URL:            https://github.com/alibaba/anolisa
Source0:        %{name}-%{version}.tar.gz

BuildRequires:  nodejs >= 20
BuildRequires:  make
Requires:       nodejs >= 20
Requires(post):	  lua
Requires(postun): lua
Provides:       %{_bindir}/co %{_bindir}/copilot %{_bindir}/cosh

%description
Copilot Shell - Entrance to AI-native OS.
AI-powered assistant that helps developers through natural language interaction.

%prep
%setup -q

%build
make deps-ci
make build

%install
rm -rf %{buildroot}
make install DESTDIR=%{buildroot} PREFIX=%{_prefix}

%files
%license %{_docdir}/%{name}/LICENSE
%doc %{_docdir}/%{name}/README.md
%{_prefix}/lib/%{name}
%{_datadir}/%{name}
%{_bindir}/co
%{_bindir}/copilot
%{_bindir}/cosh

%post -p <lua>
nl        = '\n'
cosh      = '%{_bindir}/cosh'..nl
f = io.open('/etc/shells', 'a+')
if f then
  local shells = nl..f:read('*all')..nl
  if not shells:find(nl..cosh) then f:write(cosh) end
  f:close()
end

%postun -p <lua>
-- Run it only if we are uninstalling
if arg[2] == 0
then
  t={}
  for line in io.lines("/etc/shells")
  do
    if line ~= "%{_bindir}/cosh"
    then
      table.insert(t,line)
    end
  end

  f = io.open("/etc/shells", "w+")
  for n,line in pairs(t)
  do
    f:write(line.."\n")
  end
  f:close()
end

%changelog
* Wed Mar 26 2026 Shenglong Zhu <shenglongzhu@linux.alibaba.com> - 2.0.0-1
- Initial RPM package
